# ─────────────────────────────────────────────
#  PharmaChain .gitignore
#  NEVER commit secrets, venvs, or build output
# ─────────────────────────────────────────────

# ── Secrets / Environment files ──────────────
.env
.env.local
.env.*.local
backend/.env
frontend/.env
*.pem
*.key
*.p12
*.pfx
*.cert
*.cer

# ── Python ───────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.tox/
htmlcov/
.coverage
coverage.xml
*.cover

# ── Virtual environments ──────────────────────
.venv/
venv/
env/
ENV/
backend/venv/
backend/.venv/

# ── Node / Frontend ───────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.cache/
.npm/
*.tsbuildinfo

# ── Build artifacts ───────────────────────────
*.pyc
*.pyo
*.pyd

# ── Generated QR codes (created at runtime) ──
backend/static/qr/*
!backend/static/qr/.gitkeep

# ── Logs ─────────────────────────────────────
*.log
*.log.*
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Database / Redis dumps ────────────────────
*.sqlite3
*.db
dump.rdb

# ── IDE / Editor ─────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# ── OS generated ─────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── Alembic ───────────────────────────────────
# Keep migrations but ignore local override files
alembic/versions/__pycache__/

# ── Docker ────────────────────────────────────
.docker/

# ── Temporary / debug scripts ────────────────
fix_*.py
debug_*.py
temp_*.py
scratch_*.py
test_manual_*.py
