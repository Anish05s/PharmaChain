# Backend Environment Variables
# Copy this file to .env and fill in your real values
# NEVER commit the actual .env file to git

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/pharmachain
REDIS_URL=redis://localhost:6379

# ── App / Auth ────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-min-32-chars-CHANGE-IN-PRODUCTION
ENVIRONMENT=development

# ── URLs ──────────────────────────────────────
PUBLIC_APP_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Blockchain (Ethereum Sepolia) ─────────────
# Leave all three empty to run in MOCK MODE (safe for local dev)
# Get a free Alchemy RPC URL at: https://dashboard.alchemy.com
ETHEREUM_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# Your wallet private key — NEVER share or commit this
ETHEREUM_PRIVATE_KEY=0xYOUR_WALLET_PRIVATE_KEY_WITHOUT_QUOTES
# Deployed contract address after running: npx hardhat run scripts/deploy.js
CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS

# ── External APIs ─────────────────────────────
# Free NewsAPI key at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here
# SendGrid for email alerts (optional): https://sendgrid.com
SENDGRID_API_KEY=your_sendgrid_api_key_here
# Free Mapbox token at: https://account.mapbox.com
MAPBOX_TOKEN=your_mapbox_public_token_here
# Free Gemini API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
